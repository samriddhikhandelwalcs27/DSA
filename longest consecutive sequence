class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        myset = set(nums)   
        largest = 0

        for num in myset:
            if num - 1 not in myset:   
                x = num
                count = 1              
                while x + 1 in myset:
                    count += 1
                    x += 1
                largest = max(largest, count)

        return largest
